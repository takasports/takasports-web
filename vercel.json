{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/stat-snapshots?sport=motogp",
      "schedule": "30 6 * * 1"
    },
    {
      "path": "/api/cron/stat-snapshots?sport=ufc",
      "schedule": "45 6 * * 1"
    },
    {
      "path": "/api/cron/stat-snapshots?sport=fifa",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/sync-past-results",
      "schedule": "0 5 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
