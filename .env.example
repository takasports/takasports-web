# ─────────────────────────────────────────────────────────────────
# TakaSports Web — variables de entorno
# Copia este archivo a .env.local y rellena los valores.
# Las NEXT_PUBLIC_* se exponen al navegador; el resto son server-only.
# ─────────────────────────────────────────────────────────────────

# ── Sitio ──────────────────────────────────────────────────────────
# URL canónica de producción (sin barra final).
NEXT_PUBLIC_SITE_URL=https://www.takasportsmedia.com

# ── Sanity CMS ─────────────────────────────────────────────────────
# projectId y dataset del proyecto Sanity. El write token solo se usa
# en scripts/ingesta; el webhook secret valida el POST de /api/sanity-webhook.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_WRITE_TOKEN=
SANITY_WEBHOOK_SECRET=

# ── Supabase ───────────────────────────────────────────────────────
# URL y anon key son públicas (RLS protege). Service role key es secreta:
# salta RLS, solo para rutas server (app_secrets, push_subscriptions, etc.).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Instagram (Graph API) ──────────────────────────────────────────
# Token largo de @taka.sports (expira ~60 días, lo refresca WF-10/n8n).
# App ID/Secret/Redirect solo para el flujo OAuth de re-autorización.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://www.takasportsmedia.com/api/instagram/callback

# ── APIs deportivas ────────────────────────────────────────────────
# api-sports.io (stats) y the-odds-api.com (cuotas de la quiniela).
API_SPORTS_KEY=
ODDS_API_KEY=

# ── Web Push (notificaciones) ──────────────────────────────────────
# Par de claves VAPID. La pública va al cliente; la privada firma los
# envíos. PUSH_BROADCAST_SECRET protege /api/push/send.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:hola@takasportsmedia.com
PUSH_BROADCAST_SECRET=

# ── Analytics (opcional — gated por consentimiento RGPD) ───────────
# Si están vacías, no se carga GA4 ni Clarity. El ConsentBanner decide.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=

# ── Acceso al panel /admin ─────────────────────────────────────────
# Lista (CSV) de emails autorizados a entrar en /admin/*. La comprobación
# es case-insensitive contra el email del usuario autenticado vía Supabase.
# Si está vacío en producción, /admin/* queda cerrado.
ADMIN_EMAILS=

# ── Secretos de cron / admin / ingesta ─────────────────────────────
# CRON_SECRET valida los crons de Vercel y GitHub Actions.
# Los *_ADMIN_TOKEN protegen llamadas server-to-server (n8n, scripts) a
# los endpoints /api/admin/*, /api/rankings/*, etc. El panel /admin usa
# sesión Supabase + ADMIN_EMAILS, no estos tokens.
CRON_SECRET=
INDEXNOW_SECRET=
GAMES_ADMIN_TOKEN=
RANKINGS_ADMIN_TOKEN=
REELS_INGEST_SECRET=
# Firma los tokens HMAC del enlace "darse de baja" en cada email de
# newsletter. Rotar este valor invalida TODOS los tokens pendientes,
# útil ante una filtración.
NEWSLETTER_UNSUB_SECRET=

# ── Flags de la Quiniela ───────────────────────────────────────────
# QUINIELA_DEV_ODDS: usar cuotas mock en desarrollo (jamás en prod).
# QUINIELA_MUNDIAL: activa el modo Mundial.
QUINIELA_DEV_ODDS=
QUINIELA_MUNDIAL=
